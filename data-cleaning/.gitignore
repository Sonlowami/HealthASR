# --- Do NOT commit (large or machine-specific) ---

# Raw Common Voice downloads — very large, download locally
data/raw/*
!data/raw/.gitkeep

# Pipeline outputs — regenerated by scripts
data/cleaned/*
!data/cleaned/.gitkeep
data/processed/*
!data/processed/.gitkeep
outputs/*
!outputs/.gitkeep

# Audio and feature artifacts (belt-and-suspenders; live under data/ or outputs/)
*.wav
*.npy

# Python environment and cache
venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Secrets and local config
.env
.env.*

# OS junk
.DS_Store
Thumbs.db
